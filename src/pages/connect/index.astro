---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Connect — Fiduciary Health Guide',
  description: 'A confidential conversation about coordinating behavioral health resources for families of significant means.',
  publisher: {
    '@type': 'Organization',
    name: 'Fiduciary Health Guide',
    url: 'https://fiduciaryhealthguide.com',
  },
};
---

<BaseLayout
  title="Connect — Fiduciary Health Guide"
  description="When your client or family member needs behavioral health coordination that requires discretion, expertise, and an understanding of the complexities that accompany significant wealth."
  schema={schema}
>
  <div class="connect-hero">
    <div class="container content-width">
      <h1>Connect</h1>
      <p class="lead">
        When the situation requires more than information — when it requires coordination.
      </p>
    </div>
  </div>

  <div class="connect-section">
    <div class="container content-width">
      <h2>A Practice, Not a Publication</h2>
      <p>
        We built this resource because the information should exist in public. But the practice came first. We coordinate behavioral health responses for families of significant means — the work that happens when an advisor calls at 11 PM because a client's adult child has been hospitalized, or when a trust officer realizes the settlor's decision-making capacity is deteriorating faster than anyone anticipated.
      </p>
      <p>
        We have placed clinical companions with adolescents at boarding schools in four countries. We have coordinated simultaneous interventions involving legal counsel in three jurisdictions. We have managed treatment transitions for executives whose absence from a publicly traded company required narrative coordination with crisis communications teams. We have assembled and overseen multidisciplinary care teams for families navigating addiction, cognitive decline, eating disorders, and acute psychiatric crises — often while maintaining the discretion their circumstances demand.
      </p>
      <p>
        No advertising. No affiliate relationships with treatment providers. No referral fees. Independent coordination, referral-based practice, absolute discretion.
      </p>
    </div>
  </div>

  <div class="connect-section section--stone">
    <div class="container content-width">
      <h2>What Coordination Looks Like</h2>
      <p>
        A family member's substance use crisis does not present as a single problem. It arrives as a clinical emergency, a legal exposure, a reputational risk, a family rupture, and a fiduciary question — simultaneously, often within hours. The professionals involved typically do not know each other and have never coordinated across these domains.
      </p>
      <p>
        We sit at the center. We identify and vet the right clinical resources. We facilitate communication between treatment teams, legal counsel, and family advisors. We coordinate with concierge physicians, crisis communications specialists, and family office staff. We do not provide clinical care, legal advice, or financial counsel. We ensure the professionals who do are identified, vetted, and aligned.
      </p>
    </div>
  </div>

  <div class="connect-section">
    <div class="container content-width">
      <h2>Begin a Confidential Conversation</h2>
      <p>
        A conversation carries no obligation. We will listen, assess whether our coordination capabilities fit the situation, and — if they do not — direct you to resources better suited.
      </p>
      <p>
        <strong>For encrypted communication:</strong> Reach us on Signal. Contact details provided upon initial inquiry below, or reference our Signal availability with professionals who have previously engaged our coordination services.
      </p>

      <form class="connect-form" name="connect" method="POST" action="/connect/thank-you/" data-netlify="true" netlify-honeypot="bot-field" id="connect-form">
        <input type="hidden" name="form-name" value="connect" />
        <p class="hidden" style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="form-group">
          <label for="contact-method">Preferred Contact Method</label>
          <select id="contact-method" name="contact_method" required>
            <option value="" disabled selected>Select your preference</option>
            <option value="signal">Signal (encrypted)</option>
            <option value="phone">Phone</option>
            <option value="email">Email</option>
          </select>
        </div>

        <div class="form-group">
          <label for="contact-detail">Phone Number or Email Address</label>
          <input type="text" id="contact-detail" name="contact_detail" required />
        </div>

        <div style="text-align: center;">
          <button type="submit" class="form-submit">Begin a Conversation</button>
        </div>
      </form>
    </div>
  </div>

  <div class="trust-signals">
    <div class="container content-width">
      <p>No advertising. No affiliate relationships. Absolute discretion.</p>
      <p>Global network. Independent coordination. Referral-based practice.</p>
    </div>
  </div>
</BaseLayout>
